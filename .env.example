# Indian Art SDXL Configuration
# Copy this to .env and fill in your values

# Model Configuration
BASE_MODEL=stabilityai/stable-diffusion-xl-base-1.0
LORA_PATH=path/to/your/lora.safetensors
LORA_ADAPTER_NAME=indian_art

# Generation Defaults
DEFAULT_WIDTH=1024
DEFAULT_HEIGHT=1024
DEFAULT_STEPS=30
DEFAULT_GUIDANCE=7.5
DEFAULT_LORA_SCALE=0.8

# Device (cuda or cpu)
DEVICE=cuda

# Cache directory (use /tmp for HF Spaces)
CACHE_DIR=/tmp/huggingface

# Gradio Settings
GRADIO_THEME=soft
GRADIO_SHARE=false

# Server
PORT=7860
